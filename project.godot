; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="pixel_topdown"
run/main_scene="uid://dklbhr8p1cvgl"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://graphics/icon.svg"

[autoload]

PhantomCameraManager="*uid://duq6jhf6unyis"
Inventory="*res://scripts/globals/Inventory.gd"
TransitionLayer="*res://scenes/UI/transition_layer.tscn"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/resizable=false
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/phantom_camera/plugin.cfg")

